# Copy this file to .env and fill in the required values for local development.

# API
# Primary application database connection string.
ConnectionStrings__DefaultConnection=

# Supabase project settings used by the API.
Supabase__Url=
Supabase__AnonKey=
Supabase__JwtIssuer=

# Supabase storage settings used by the API.
Storage__Url=
Storage__Key=
Storage__Bucket=

# Stripe secrets used by the API.
Stripe__SecretKey=
Stripe__WebhookSecret=

# Frontend
# Documented local API base URL aligned with the API launch profile.
# Current storefront/admin SSR clients still resolve `/api/storefront` relative to the app origin in code.
NG_APP_API_BASE_URL=http://localhost:5297/api
